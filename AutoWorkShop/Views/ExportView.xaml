<UserControl x:Class="AutoWorkshop.Views.ExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Выберите данные для экспорта:" FontSize="16" 
                   FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <CheckBox x:Name="ExportClients" Content="Клиенты" FontSize="14" Margin="0,10"/>
            <CheckBox x:Name="ExportCars" Content="Автомобили" FontSize="14" Margin="0,10"/>
            <CheckBox x:Name="ExportOrders" Content="Заказы" FontSize="14" Margin="0,10"/>
            <CheckBox x:Name="ExportParts" Content="Запчасти" FontSize="14" Margin="0,10"/>
            <CheckBox x:Name="ExportEmployees" Content="Сотрудники" FontSize="14" Margin="0,10"/>
            <CheckBox x:Name="ExportFinance" Content="Финансы" FontSize="14" Margin="0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="📤 Экспортировать" Width="150" Height="35" Margin="0,0,10,0" 
                    Background="#007ACC" Foreground="White" Click="Export_Click"/>
            <Button Content="✅ Выбрать всё" Width="120" Height="35" Click="SelectAll_Click"/>
        </StackPanel>
    </Grid>
</UserControl>