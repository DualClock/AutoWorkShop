<UserControl x:Class="AutoWorkshop.Views.DepartmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <GroupBox Grid.Column="0" Header="Отделы" Margin="0,0,20,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="AddDepartmentButton" Content="➕ Добавить" Width="110" Height="30" Margin="0,0,5,0"
                            Background="#007ACC" Foreground="White" Click="AddDepartment_Click"/>
                    <Button x:Name="EditDepartmentButton" Content="✏️ Изменить" Width="110" Height="30" Margin="0,0,5,0"
                            Background="#FFA500" Foreground="White" Click="EditDepartment_Click"/>
                    <Button x:Name="DeleteDepartmentButton" Content="🗑️ Удалить" Width="110" Height="30" Margin="0,0,0,0"
                            Background="#DC3545" Foreground="White" Click="DeleteDepartment_Click"/>
                </StackPanel>

                <ListBox x:Name="DepartmentsListBox" Grid.Row="1" SelectionChanged="DepartmentsListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontSize="16" Margin="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        
        <GroupBox Grid.Column="1" Header="Сотрудники отдела">
            <DataGrid x:Name="EmployeesDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="150"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>