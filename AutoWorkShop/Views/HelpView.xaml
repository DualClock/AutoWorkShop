<UserControl x:Class="AutoWorkshop.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <TabControl>
            <TabItem Header="📖 Руководство">
                <ScrollViewer Padding="20">
                    <StackPanel>
                        <TextBlock Text="Руководство пользователя" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                        <TextBlock Text="1. Как добавить клиента:" FontSize="14" FontWeight="Bold" Margin="0,10"/>
                        <TextBlock Text="   - Перейдите на вкладку «Клиенты»" Margin="0,5"/>
                        <TextBlock Text="   - Нажмите «Добавить клиента»" Margin="0,5"/>
                        <TextBlock Text="   - Заполните форму и сохраните" Margin="0,5"/>

                        <TextBlock Text="2. Как зарегистрировать автомобиль:" FontSize="14" FontWeight="Bold" Margin="0,20,0,5"/>
                        <TextBlock Text="   - Перейдите на вкладку «Автомобили»" Margin="0,5"/>
                        <TextBlock Text="   - Нажмите «Добавить автомобиль»" Margin="0,5"/>

                        <TextBlock Text="3. Как создать заказ:" FontSize="14" FontWeight="Bold" Margin="0,20,0,5"/>
                        <TextBlock Text="   - Перейдите на вкладку «Заказы»" Margin="0,5"/>
                        <TextBlock Text="   - Нажмите «Новый заказ»" Margin="0,5"/>

                        <TextBlock Text="4. Как формировать отчёты:" FontSize="14" FontWeight="Bold" Margin="0,20,0,5"/>
                        <TextBlock Text="   - Используйте вкладку «Финансы» или «Статистика»" Margin="0,5"/>
                        <TextBlock Text="   - Нажмите «Экспорт в Excel» или «Сформировать отчёт»" Margin="0,5"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="ℹ️ О программе">
                <StackPanel Margin="20">
                    <TextBlock Text="АвтоМаст ИС" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="Версия: 1.0.0" FontSize="14" Margin="0,0,0,5"/>
                    <TextBlock Text="Дата сборки: 2026" FontSize="14" Margin="0,0,0,5"/>
                    <TextBlock Text="Технологии: WPF, C#, .NET, SQL Server" FontSize="14" Margin="0,0,0,20"/>
                    <TextBlock Text="© 2026 ООО «АвтоМаст»" FontSize="12" Foreground="#666"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>