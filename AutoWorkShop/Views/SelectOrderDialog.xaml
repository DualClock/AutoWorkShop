<Window x:Class="AutoWorkshop.Views.SelectOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выберите заказ" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" x:Name="OrdersDataGrid" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Автомобиль" Binding="{Binding Car.PlateNumber}" Width="120"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Car.Client.FullName}" Width="200"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalCost}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Выбрать" Width="100" Height="35" Margin="0,0,10,0" 
                    Background="#007ACC" Foreground="White" Click="Select_Click"/>
            <Button Content="Отмена" Width="100" Height="35" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>