<UserControl x:Class="AutoWorkshop.Views.NotificationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="📩 Новое уведомление" Width="150" Height="35" Margin="0,0,10,0"
                    Background="#007ACC" Foreground="White" Click="NewNotification_Click"/>
            <Button Content="🗑️ Удалить" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#DC3545" Foreground="White" Click="DeleteNotification_Click"/>
            <Button Content="✅ Отметить все" Width="120" Height="35" Margin="0,0,0,0"
                    Background="#6C757D" Foreground="White" Click="MarkAllRead_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="NotificationsDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  Margin="0,10,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="*"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedDate}" Width="120"/>
                <DataGridCheckBoxColumn Header="Прочитано" Binding="{Binding IsRead}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>