<UserControl x:Class="AutoWorkshop.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="📝 Новый заказ" Width="150" Height="35" Margin="0,0,10,0"
                    Background="#007ACC" Foreground="White" Click="NewOrder_Click"/>
            <Button Content="✏️ Редактировать" Width="150" Height="35" Margin="0,0,10,0"
                    Background="#FFA500" Foreground="White" Click="EditOrder_Click"/>
            <Button Content="🗑️ Удалить" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#DC3545" Foreground="White" Click="DeleteOrder_Click"/>
            <Button Content="🔄 Обновить" Width="100" Height="35" Margin="0,0,0,0"
                    Background="#6C757D" Foreground="White" Click="Refresh_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="OrdersDataGrid" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" Margin="0,10,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Автомобиль" Binding="{Binding Car.PlateNumber}" Width="120"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Car.Client.FullName}" Width="150"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalCost}" Width="100"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedDate}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>