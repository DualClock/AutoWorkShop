<Window x:Class="AutoWorkshop.Views.AddCarDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление автомобиля" Height="500" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0">
            <TextBlock Text="Клиент:" Margin="0,0,0,5" FontWeight="Bold"/>
            <ComboBox x:Name="ClientComboBox" Height="30" Margin="0,0,0,15" 
                      DisplayMemberPath="FullName"/>
            
            <TextBlock Text="Марка:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="BrandTextBox" Height="30" Margin="0,0,0,15"/>
            
            <TextBlock Text="Модель:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="ModelTextBox" Height="30" Margin="0,0,0,15"/>
            
            <TextBlock Text="VIN:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="VinTextBox" Height="30" Margin="0,0,0,15"/>
            
            <TextBlock Text="Гос. номер:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="PlateNumberTextBox" Height="30" Margin="0,0,0,15"/>
            
            <TextBlock Text="Год выпуска:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="YearTextBox" Height="30" Margin="0,0,0,15"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0" 
                    Background="#007ACC" Foreground="White" Click="Save_Click"/>
            <Button Content="Отмена" Width="100" Height="35" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>