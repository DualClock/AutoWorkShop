<UserControl x:Class="AutoWorkshop.Views.ReceiptsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="📄 Сформировать квитанцию" Width="180" Height="35" Margin="0,0,10,0"
                    Background="#007ACC" Foreground="White" Click="GenerateReceipt_Click"/>
            <Button Content="🖨️ Печать" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#28A745" Foreground="White" Click="Print_Click"/>
            <Button Content="📩 Уведомить клиента" Width="150" Height="35" Margin="0,0,10,0"
                    Background="#FFC107" Foreground="Black" Click="NotifyClient_Click"/>
            <Button Content="🔄 Обновить" Width="100" Height="35" Margin="0,0,0,0"
                    Background="#6C757D" Foreground="White" Click="Refresh_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="ReceiptsDataGrid" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" Margin="0,10,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="№ заказа" Binding="{Binding OrderId}" Width="80"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount}" Width="100"/>
                <DataGridTextColumn Header="Дата оплаты" Binding="{Binding PaymentDate}" Width="120"/>
                <DataGridTextColumn Header="Оплачено" Binding="{Binding IsPaid}" Width="80"/>
                <DataGridTextColumn Header="№ квитанции" Binding="{Binding ReceiptNumber}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>