<Window x:Class="AutoWorkshop.Views.EditOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заказа" Height="550" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Автомобиль:" Margin="0,0,0,5" FontWeight="Bold"/>
            <ComboBox x:Name="CarComboBox" Height="30" Margin="0,0,0,15"
                      DisplayMemberPath="PlateNumber"/>

            <TextBlock Text="Сотрудник:" Margin="0,0,0,5" FontWeight="Bold"/>
            <ComboBox x:Name="EmployeeComboBox" Height="30" Margin="0,0,0,15"
                      DisplayMemberPath="FullName"/>

            <TextBlock Text="Описание проблемы:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="DescriptionTextBox" Height="80" Margin="0,0,0,15"
                     TextWrapping="Wrap" AcceptsReturn="True"/>

            <TextBlock Text="Статус:" Margin="0,0,0,5" FontWeight="Bold"/>
            <ComboBox x:Name="StatusComboBox" Height="30" Margin="0,0,0,15">
                <ComboBox.Items>
                    <ComboBoxItem Content="Новый"/>
                    <ComboBoxItem Content="В работе"/>
                    <ComboBoxItem Content="Готов"/>
                    <ComboBoxItem Content="Закрыт"/>
                </ComboBox.Items>
            </ComboBox>

            <TextBlock Text="Стоимость (руб.):" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="CostTextBox" Height="30" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#007ACC" Foreground="White" Click="Save_Click"/>
            <Button Content="Отмена" Width="100" Height="35"
                    Background="#6C757D" Foreground="White" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
