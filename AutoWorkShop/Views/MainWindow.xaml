<Window x:Class="AutoWorkshop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AutoWorkshop.Views"
        Title="АвтоМаст ИС - Главная" Height="700" Width="1200"
        WindowState="Maximized"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" Background="#007ACC" BorderThickness="0,0,0,1" BorderBrush="#005A9E">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔧 АвтоМаст ИС" FontSize="24" 
                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UserNameText" Text="Администратор" FontSize="16" 
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="Выход" Width="100" Height="35" 
                            Background="#E74C3C" Foreground="White" BorderThickness="0"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        
        <TabControl Grid.Row="1" Margin="20" Background="White" BorderThickness="0"
                    x:Name="MainTabControl">

            
            <TabItem Header="📋 Главная" FontSize="14">
                <Grid Margin="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Добро пожаловать в систему АвтоМаст ИС!" 
                                   FontSize="24" FontWeight="Bold" Foreground="#333" 
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="Выберите раздел в меню для начала работы" 
                                   FontSize="16" Foreground="#666" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="" 
                                   FontSize="14" Foreground="#007ACC" 
                                   HorizontalAlignment="Center" Margin="0,30,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            
            <TabItem Header="👥 Клиенты" FontSize="14">
                <views:ClientsView/>
            </TabItem>

            
            <TabItem Header="📝 Заказы" FontSize="14">
                <views:OrdersView/>
            </TabItem>

            
            <TabItem Header="🏭 Отделы" FontSize="14">
                <views:DepartmentsView/>
            </TabItem>

            
            <TabItem Header="📦 Запчасти" FontSize="14">
                <views:PartsView/>
            </TabItem>

            
            <TabItem Header="🚗 Автомобили" FontSize="14">
                <views:CarsView/>
            </TabItem>

            
            <TabItem Header="👨‍🔧 Сотрудники" FontSize="14">
                <views:EmployeesView/>
            </TabItem>

            
            <TabItem Header="💰 Финансы" FontSize="14">
                <views:FinanceView/>
            </TabItem>

            
            <TabItem Header="📊 Статистика" FontSize="14">
                <views:StatisticsView/>
            </TabItem>

            
            <TabItem Header="📤 Экспорт данных" FontSize="14">
                <views:ExportView/>
            </TabItem>

            
            <TabItem Header="👥 Пользователи" FontSize="14">
                <views:UsersView/>
            </TabItem>

            
            <TabItem Header="⚙️ Настройки" FontSize="14">
                <views:SettingsView/>
            </TabItem>

            
            <TabItem Header="💾 Резервное копирование" FontSize="14">
                <views:BackupView/>
            </TabItem>

            
            <TabItem Header="🔔 Уведомления" FontSize="14">
                <views:NotificationsView/>
            </TabItem>

            
            <TabItem Header="❓ Справка" FontSize="14">
                <views:HelpView/>
            </TabItem>

        </TabControl>

        
        <Border Grid.Row="2" Background="#333" BorderThickness="0,1,0,0" BorderBrush="#555">
            <TextBlock x:Name="StatusBarText" Text="Готов к работе" FontSize="12" 
                       Foreground="White" VerticalAlignment="Center" Margin="20,0"/>
        </Border>
    </Grid>
</Window>