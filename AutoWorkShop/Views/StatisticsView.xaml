<UserControl x:Class="AutoWorkshop.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Фильтры -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="FromDatePicker" Width="120" Margin="0,0,20,0"/>
            <TextBlock Text="по" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="ToDatePicker" Width="120" Margin="0,0,20,0"/>
            <Button Content="Применить" Width="100" Height="35" Click="ApplyFilter_Click"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="📄 Сформировать отчёт" Width="150" Height="35" Margin="0,0,10,0" 
                    Background="#007ACC" Foreground="White" Click="GenerateReport_Click"/>
            <Button Content="🔄 Обновить" Width="100" Height="35" Click="Refresh_Click"/>
        </StackPanel>

        <!-- Статистика по маркам -->
        <GroupBox Grid.Row="2" Header="Статистика по маркам автомобилей">
            <DataGrid x:Name="StatsDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Марка" Binding="{Binding Brand}" Width="150"/>
                    <DataGridTextColumn Header="Количество ремонтов" Binding="{Binding Count}" Width="150"/>
                    <DataGridTextColumn Header="Выручка" Binding="{Binding Revenue}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>