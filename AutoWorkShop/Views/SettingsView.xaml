<UserControl x:Class="AutoWorkshop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Информация об автомастерской" Margin="0,0,0,20">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="0,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameTextBox" Height="30" Margin="10,10" Text="АвтоМаст"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Адрес:" VerticalAlignment="Center" Margin="0,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="AddressTextBox" Height="30" Margin="10,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" Margin="0,10"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="PhoneTextBox" Height="30" Margin="10,10"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Email:" VerticalAlignment="Center" Margin="0,10"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="EmailTextBox" Height="30" Margin="10,10"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="💾 Сохранить" Width="120" Height="35" Margin="0,0,10,0" 
                    Background="#007ACC" Foreground="White" Click="Save_Click"/>
            <Button Content="🔄 Сбросить" Width="100" Height="35" Click="Reset_Click"/>
        </StackPanel>
    </Grid>
</UserControl>