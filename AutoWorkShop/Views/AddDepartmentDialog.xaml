<Window x:Class="AutoWorkshop.Views.AddDepartmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление отдела" Height="200" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Название отдела:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="NameTextBox" Height="30" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#007ACC" Foreground="White" Click="Save_Click"/>
            <Button Content="Отмена" Width="100" Height="35"
                    Background="#6C757D" Foreground="White" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
