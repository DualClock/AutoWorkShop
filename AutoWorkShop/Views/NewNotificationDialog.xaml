<Window x:Class="AutoWorkshop.Views.NewNotificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новое уведомление" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Тип уведомления:" Margin="0,0,0,5" FontWeight="Bold"/>
            <ComboBox x:Name="TypeComboBox" Height="30" Margin="0,0,0,15">
                <ComboBox.Items>
                    <ComboBoxItem Content="Информация"/>
                    <ComboBoxItem Content="Предупреждение"/>
                    <ComboBoxItem Content="Ошибка"/>
                    <ComboBoxItem Content="Напоминание"/>
                </ComboBox.Items>
            </ComboBox>

            <TextBlock Text="Сообщение:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="MessageTextBox" Height="100" Margin="0,0,0,15"
                     TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Создать" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#007ACC" Foreground="White" Click="Create_Click"/>
            <Button Content="Отмена" Width="100" Height="35"
                    Background="#6C757D" Foreground="White" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
