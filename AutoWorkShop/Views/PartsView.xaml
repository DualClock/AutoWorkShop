<UserControl x:Class="AutoWorkshop.Views.PartsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="➕ Добавить запчасть" Width="150" Height="35" Margin="0,0,10,0" 
                    Background="#007ACC" Foreground="White" Click="AddPart_Click"/>
            <Button Content="✏️ Изменить количество" Width="150" Height="35" Margin="0,0,10,0" 
                    Background="#28A745" Foreground="White" Click="EditQuantity_Click"/>
            <Button Content="📦 Заказать поставку" Width="150" Height="35" Margin="0,0,10,0" 
                    Background="#FFC107" Foreground="Black" Click="OrderSupply_Click"/>
            <Button Content="📄 Печать отчёта" Width="120" Height="35" Margin="0,0,10,0" 
                    Background="#17A2B8" Foreground="White" Click="PrintReport_Click"/>
            <Button Content="🔄 Обновить" Width="100" Height="35" Click="Refresh_Click"/>
        </StackPanel>

        <!-- Таблица запчастей -->
        <DataGrid Grid.Row="1" x:Name="PartsDataGrid" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="120"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinQuantity}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>