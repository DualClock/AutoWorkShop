<UserControl x:Class="AutoWorkshop.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Резервное копирование базы данных" FontSize="18" 
                   FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Создайте резервную копию для восстановления данных в случае сбоя." 
                       FontSize="14" Margin="0,0,0,30" TextWrapping="Wrap"/>

            <Button Content="💾 Создать резервную копию" Width="200" Height="45" Margin="0,0,0,20" 
                    Background="#28A745" Foreground="White" FontSize="16" Click="CreateBackup_Click"/>

            <Button Content="📂 Восстановить из копии" Width="200" Height="45" 
                    Background="#FFC107" Foreground="Black" FontSize="16" Click="RestoreBackup_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2" x:Name="StatusText" Text="" FontSize="12" 
                   Foreground="#666" Margin="0,20,0,0"/>
    </Grid>
</UserControl>