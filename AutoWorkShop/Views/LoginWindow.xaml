<Window x:Class="AutoWorkshop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - АвтоМаст ИС" Height="450" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0">

    <Grid>
        <Border Background="White" CornerRadius="15" Margin="30"
                BorderBrush="#007ACC" BorderThickness="2">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
                <TextBlock Text="🔧 АвтоМаст ИС" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#333"/>

                <TextBlock Text="Логин" FontSize="14" Foreground="#666" Margin="0,0,0,8"/>
                <TextBox x:Name="LoginTextBox" Height="40" FontSize="16"
                         Background="#FAFAFA" BorderBrush="#CCC" BorderThickness="1"
                         Padding="10,0,0,0">
                    <TextBox.Text>admin</TextBox.Text>
                </TextBox>

                <TextBlock Text="Пароль" FontSize="14" Foreground="#666" Margin="0,20,0,8"/>
                <PasswordBox x:Name="PasswordBox" Height="40" FontSize="16"
                             Background="#FAFAFA" BorderBrush="#CCC" BorderThickness="1"
                             Padding="10,0,0,0">
                    <PasswordBox.Password>admin123</PasswordBox.Password>
                </PasswordBox>

                <Button Content="Войти в систему" Margin="0,35,0,0" Height="45"
                        Background="#007ACC" Foreground="White" FontSize="16" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        Click="LoginButton_Click"/>

                <TextBlock x:Name="ErrorText" Text="" Foreground="#E74C3C"
                           HorizontalAlignment="Center" Margin="0,20,0,0"
                           FontSize="14" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>