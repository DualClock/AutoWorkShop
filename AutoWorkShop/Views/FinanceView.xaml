<UserControl x:Class="AutoWorkshop.Views.FinanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Background="#007ACC" CornerRadius="10" Padding="20" Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="Общая выручка" FontSize="14" Foreground="White"/>
                    <TextBlock x:Name="TotalRevenueText" Text="0 ₽" FontSize="24" 
                               FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>

            <Border Background="#28A745" CornerRadius="10" Padding="20" Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="Средний чек" FontSize="14" Foreground="White"/>
                    <TextBlock x:Name="AverageCheckText" Text="0 ₽" FontSize="24" 
                               FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>

            <Border Background="#FFC107" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="Всего заказов" FontSize="14" Foreground="Black"/>
                    <TextBlock x:Name="TotalOrdersText" Text="0" FontSize="24" 
                               FontWeight="Bold" Foreground="Black"/>
                </StackPanel>
            </Border>
        </StackPanel>

        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="📊 Экспорт в Excel" Width="150" Height="35" Margin="0,0,10,0"
                    Background="#17A2B8" Foreground="White" Click="ExportToExcel_Click"/>
            <Button Content="🔄 Обновить" Width="100" Height="35" Margin="0,0,0,0"
                    Background="#6C757D" Foreground="White" Click="Refresh_Click"/>
        </StackPanel>

        
        <DataGrid Grid.Row="2" x:Name="FinanceDataGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  Margin="0,10,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ заказа" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedDate}" Width="120"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalCost}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>