<Window x:Class="AutoWorkshop.Views.EditPartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование запчасти" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Наименование:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="NameTextBox" Height="30" Margin="0,0,0,15"/>

            <TextBlock Text="Артикул:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="ArticleTextBox" Height="30" Margin="0,0,0,15"/>

            <TextBlock Text="Количество:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="QuantityTextBox" Height="30" Margin="0,0,0,15"/>

            <TextBlock Text="Цена:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="PriceTextBox" Height="30" Margin="0,0,0,15"/>

            <TextBlock Text="Мин. остаток:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox x:Name="MinQuantityTextBox" Height="30" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#007ACC" Foreground="White" Click="Save_Click"/>
            <Button Content="Отмена" Width="100" Height="35"
                    Background="#6C757D" Foreground="White" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
